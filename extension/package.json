{
  "name": "@watch-party-sync/extension",
  "version": "0.2.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build": "pnpm --filter @watch-party-sync/protocol build && wxt build",
    "build:firefox": "pnpm --filter @watch-party-sync/protocol build && wxt build -b firefox",
    "check": "wxt prepare && tsc --noEmit",
    "dev": "wxt",
    "test": "pnpm --filter @watch-party-sync/protocol build && wxt prepare && vitest run",
    "zip": "pnpm build && node scripts/package-extension.mjs chrome",
    "zip:firefox": "pnpm build:firefox && node scripts/package-extension.mjs firefox"
  },
  "dependencies": {
    "@fontsource/montserrat": "^5.2.8",
    "@watch-party-sync/protocol": "workspace:*",
    "lucide-react": "^0.468.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.1.3",
    "fflate": "^0.8.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8",
    "wxt": "^0.20.8"
  }
}
