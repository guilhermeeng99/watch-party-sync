{
  "name": "@watch-party-sync/extension",
  "version": "0.1.1",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build": "pnpm --filter @watch-party-sync/protocol build && wxt build",
    "check": "wxt prepare && tsc --noEmit",
    "dev": "wxt",
    "zip": "pnpm build && wxt zip && node scripts/normalize-zip-name.mjs"
  },
  "dependencies": {
    "@fontsource/montserrat": "^5.2.8",
    "@watch-party-sync/protocol": "workspace:*",
    "lucide-react": "^0.468.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.1.3",
    "typescript": "^5.9.3",
    "wxt": "^0.20.8"
  }
}
